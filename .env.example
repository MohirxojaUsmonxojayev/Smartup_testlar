# .env NAMUNASI — nusxa oling: `cp .env.example .env`, so'ng qiymatlarni to'ldiring.
# Haqiqiy .env git'ga kirmaydi (.gitignore). Bu faylga HAQIQIY parol yozmang.

# Server (majburiy)
COMPANY_URL=https://app3.greenwhite.uz/xtrade

# Mavjud company rejimi
CREATE_COMPANY=0
COMPANY_CODE=your_company_code
COMPANY_PASSWORD=your_company_password

# Profil credentiallari (authorization(who=...) uchun).
# Berilmasa: admin -> admin@COMPANY_CODE + COMPANY_PASSWORD; user paroli -> default
ADMIN_EMAIL=admin@your_company_code
ADMIN_PASSWORD=your_admin_password
USER_PASSWORD=your_user_password

# New company/head admin rejimi. company setup uchun yoqing.
#CREATE_COMPANY=1
#HEAD_ADMIN_EMAIL=admin@head
#HEAD_ADMIN_PASSWORD=your_head_password

# Ixtiyoriy run flaglari
HEADLESS=0
NEW_CODE=0
REUSE_CODE=0
TEST_SCOPE=smoke
INCLUDE_LEAF_TESTS=0
DISABLE_LICENSE_POLICY=0
